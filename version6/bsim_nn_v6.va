// ============================================================
// BSIM-NN v6: SPICE-Compatible Neural Network MOSFET Model
// 3 inputs -> 32 tanh -> 32 tanh -> 1 output (log10 ID)
// ============================================================
// SPICE convergence features:
//  - Smooth tanh-based input clamping (no if/ternary)
//  - Minimum std 0.05 to avoid division by zero
//  - Gate/body conductance paths for Jacobian stability
//  - Weight-regularized to avoid tanh saturation
//  - Smooth VDS->0 transition
// ============================================================

`include "disciplines.vams"
`include "constants.vams"

module bsim_nn_v6(d, g, s, b);
    inout d, g, s, b; electrical d, g, s, b;

    parameter real L = 1e-6 from (0:inf);
    parameter real W = 10e-6 from (0:inf);

    real VGS, VDS, VBS, VGS_n, VDS_n, VBS_n;
    real h1_0, h1_1, h1_2, h1_3, h1_4, h1_5, h1_6, h1_7, h1_8, h1_9, h1_10, h1_11, h1_12, h1_13, h1_14, h1_15, h1_16, h1_17, h1_18, h1_19, h1_20, h1_21, h1_22, h1_23, h1_24, h1_25, h1_26, h1_27, h1_28, h1_29, h1_30, h1_31;
    real h2_0, h2_1, h2_2, h2_3, h2_4, h2_5, h2_6, h2_7, h2_8, h2_9, h2_10, h2_11, h2_12, h2_13, h2_14, h2_15, h2_16, h2_17, h2_18, h2_19, h2_20, h2_21, h2_22, h2_23, h2_24, h2_25, h2_26, h2_27, h2_28, h2_29, h2_30, h2_31;
    real log10_Id, Ids, vds_smooth;

    real mean_vgs = 0.50000000;
    real std_vgs  = 0.41231056;
    real mean_vds = 0.60050000;
    real std_vds  = 0.35311455;
    real mean_vbs = -0.25000000;
    real std_vbs  = 0.17677670;
    analog begin
        VGS = V(g, s); VDS = V(d, s); VBS = V(b, s);

        // Smooth clamp to training range via tanh
        VGS = 0.5 + 0.7 * tanh((VGS - 0.5) / 0.7);
        VDS = 0.6 + 0.6 * tanh((VDS - 0.6) / 0.6);
        VBS = -0.25 + 0.25 * tanh((VBS + 0.25) / 0.25);

        VGS_n = (VGS - mean_vgs) / std_vgs;
        VDS_n = (VDS - mean_vds) / std_vds;
        VBS_n = (VBS - mean_vbs) / std_vbs;

        // Hidden Layer 1 (tanh)

        h1_0 = tanh(0.81865501 + 0.09748114*VGS_n + 0.44684786*VDS_n + -0.01731172*VBS_n);
