        h1_9 = tanh(0.28563595 + 0.53691655*VGS_n + 0.04958789*VDS_n + 0.02850047*VBS_n);
        h1_10 = tanh(0.76688898 + 0.12526709*VGS_n + 0.39336687*VDS_n + 0.00420315*VBS_n);
