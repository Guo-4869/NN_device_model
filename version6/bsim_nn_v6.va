        h2_3 = tanh(-0.06356920 + 0.02942046*h1_0 + -0.28487059*h1_1 + 0.12254920*h1_2 + 0.50229496*h1_3 + -0.20546414*h1_4 + -0.02059009*h1_5 + 0.04441839*h1_6 + -0.09818754*h1_7 + -0.04637643*h1_8 + 0.34369531*h1_9 + 0.11488603*h1_10 + 0.11370276*h1_11 + 0.18390708*h1_12 + 0.04262248*h1_13 + -0.27515778*h1_14 + -0.00990523*h1_15 + -0.24201173*h1_16 + -0.30031958*h1_17 + 0.17759879*h1_18 + -0.07771397*h1_19 + 0.14732216*h1_20 + -0.20467913*h1_21 + -0.36121556*h1_22 + 0.14154994*h1_23 + 0.90809518*h1_24 + 0.35903257*h1_25 + 0.52132624*h1_26 + 0.23339309*h1_27 + 0.14816400*h1_28 + -0.24721535*h1_29 + -0.32145387*h1_30 + -0.03876708*h1_31);
        h2_4 = tanh(-0.69146448 + -2.70026278*h1_0 + 0.36165810*h1_1 + 0.00512460*h1_2 + -0.32074469*h1_3 + -0.28650582*h1_4 + 1.27989030*h1_5 + -0.42639270*h1_6 + -1.34320748*h1_7 + -0.85825855*h1_8 + -0.48150024*h1_9 + -1.94289708*h1_10 + -0.39717677*h1_11 + -1.66612160*h1_12 + -1.26509500*h1_13 + -0.15082438*h1_14 + -0.73154050*h1_15 + -0.11209284*h1_16 + 1.91604340*h1_17 + -0.85391939*h1_18 + -0.11386688*h1_19 + 0.32628867*h1_20 + 0.53745133*h1_21 + 0.71208823*h1_22 + -0.44525418*h1_23 + -0.19603273*h1_24 + -0.46926057*h1_25 + -0.17110258*h1_26 + 0.64897430*h1_27 + 0.91665685*h1_28 + -0.07783075*h1_29 + 0.07398251*h1_30 + 1.05488038*h1_31);
