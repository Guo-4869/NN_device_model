        h2_31 = tanh(-0.33196592 + -2.27096128*h1_0 + -0.02815354*h1_1 + -1.50584817*h1_2 + -0.62091213*h1_3 + 0.27572101*h1_4 + 0.70521688*h1_5 + -0.29489762*h1_6 + -0.26972678*h1_7 + -0.24497986*h1_8 + -0.38124377*h1_9 + -1.65571833*h1_10 + -2.60653186*h1_11 + -3.12620974*h1_12 + -0.63953477*h1_13 + -0.20016855*h1_14 + -0.30119035*h1_15 + 0.39735955*h1_16 + 5.49845600*h1_17 + -0.22976339*h1_18 + -0.02538438*h1_19 + -0.81557506*h1_20 + 0.25332960*h1_21 + 1.66962397*h1_22 + -0.06593115*h1_23 + -3.60133672*h1_24 + -0.26830491*h1_25 + -0.26788151*h1_26 + -0.01229741*h1_27 + 0.32281238*h1_28 + 0.21286882*h1_29 + 0.25189948*h1_30 + 0.63658029*h1_31);

        // Output Layer (linear)

        log10_Id = -0.32638726 + -0.95529127*h2_0 + 0.82367527*h2_1 + 0.54892546*h2_2 + 1.04795837*h2_3 + 0.54572868*h2_4 + -0.65823883*h2_5 + -0.61760694*h2_6 + 0.92893022*h2_7 + 0.60544711*h2_8 + 0.53035814*h2_9 + -0.79809791*h2_10 + -0.93398929*h2_11 + -0.86445928*h2_12 + -0.66805512*h2_13 + 0.87109649*h2_14 + 0.61018682*h2_15 + 0.73113191*h2_16 + -0.58032024*h2_17 + 0.53806096*h2_18 + 0.68012357*h2_19 + 0.74473637*h2_20 + 0.57090724*h2_21 + 0.59266776*h2_22 + -0.55280435*h2_23 + -0.75633550*h2_24 + 0.58654171*h2_25 + -0.56241071*h2_26 + 0.76511765*h2_27 + 0.64925969*h2_28 + 0.56716245*h2_29 + 0.76525313*h2_30 + -1.88717771*h2_31;

