    analog begin
        // Get input voltages
        Vgs = V(g, s);
        Vds = V(d, s);
        
        // Normalize inputs
        Vgs_n = (Vgs - mean_vgs) / scale_vgs;
        Vds_n = (Vds - mean_vds) / scale_vds;
        
        
        // ÎďŔíĆô·˘µÄĚŘŐ÷ĚáČˇ
        // Vgs ĚŘŐ÷: ĎßĐÔ, Ć˝·˝, Ö¸Ęý
        real vgs_lin = Vgs_n;
        real vgs_sq = Vgs_n * Vgs_n;
        real vgs_exp = exp(0.755309 * Vgs_n) - 1.0;
        
        // Vds ĚŘŐ÷: ĎßĐÔ, Ć˝·˝, ±ĄşÍ
        real vds_lin = Vds_n;
        real vds_sq = Vds_n * Vds_n;
        real vds_sat = tanh(1.097574 * Vds_n);

        
        // Input features
        real x[6];
        x[0] = vgs_lin;
        x[1] = vgs_sq;
        x[2] = vgs_exp;
        x[3] = vds_lin;
        x[4] = vds_sq;
        x[5] = vds_sat;
        

        // Hidden layer 1
        for (i = 0; i < 12; i = i + 1) begin
            h1[i] = b1[i];
            for (j = 0; j < 6; j = j + 1)
                h1[i] = h1[i] + w1[i][j] * x[j];
            h1[i] = tanh(h1[i]);
        end
        
        // Hidden layer 2
        for (i = 0; i < 12; i = i + 1) begin
            h2[i] = b2[i];
            for (j = 0; j < 12; j = j + 1)
                h2[i] = h2[i] + w2[i][j] * h1[j];
            h2[i] = tanh(h2[i]);
        end
        
        // Output layer
        out = b3;
        for (j = 0; j < 12; j = j + 1)
            out = out + w3[0][j] * h2[j];

        
        // Denormalize
        logIds = out * scale_logids + mean_logids;
        Ids = pow(10, logIds) * (w / l);
        
        // Output current
        I(d, s) <+ Ids;
        I(g, s) <+ 0;
    end
endmodule
