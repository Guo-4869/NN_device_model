        h1_21 = (-0.2030342221 + 0.0587789081*VGS_n + -0.0310490858*VDS_n + 0.0061512049*VBS_n) / sqrt(1 + pow(-0.2030342221 + 0.0587789081*VGS_n + -0.0310490858*VDS_n + 0.0061512049*VBS_n, 2));
        h1_22 = (-0.1905631274 + 0.0047179996*VGS_n + 0.1674784571*VDS_n + 0.0222097635*VBS_n) / sqrt(1 + pow(-0.1905631274 + 0.0047179996*VGS_n + 0.1674784571*VDS_n + 0.0222097635*VBS_n, 2));
        h1_23 = (-0.0165788904 + -0.9150486588*VGS_n + 0.0539555848*VDS_n + -0.0793440938*VBS_n) / sqrt(1 + pow(-0.0165788904 + -0.9150486588*VGS_n + 0.0539555848*VDS_n + -0.0793440938*VBS_n, 2));
        h1_24 = (0.1761886328 + 0.1023267284*VGS_n + 0.0683891475*VDS_n + 0.0222369842*VBS_n) / sqrt(1 + pow(0.1761886328 + 0.1023267284*VGS_n + 0.0683891475*VDS_n + 0.0222369842*VBS_n, 2));
        h1_25 = (0.3224983811 + 0.0109613752*VGS_n + -0.2895964682*VDS_n + 0.0022100082*VBS_n) / sqrt(1 + pow(0.3224983811 + 0.0109613752*VGS_n + -0.2895964682*VDS_n + 0.0022100082*VBS_n, 2));
        h1_26 = (0.1753184050 + -0.0090990821*VGS_n + 0.0371768028*VDS_n + 0.0809271559*VBS_n) / sqrt(1 + pow(0.1753184050 + -0.0090990821*VGS_n + 0.0371768028*VDS_n + 0.0809271559*VBS_n, 2));
        h1_27 = (-0.2366956472 + 0.0224241707*VGS_n + -0.0282455217*VDS_n + -0.0006228317*VBS_n) / sqrt(1 + pow(-0.2366956472 + 0.0224241707*VGS_n + -0.0282455217*VDS_n + -0.0006228317*VBS_n, 2));
        h1_28 = (0.1216916516 + 0.0294580683*VGS_n + 0.0196539424*VDS_n + 0.0084260916*VBS_n) / sqrt(1 + pow(0.1216916516 + 0.0294580683*VGS_n + 0.0196539424*VDS_n + 0.0084260916*VBS_n, 2));
        h1_29 = (0.5495961905 + -0.0016704479*VGS_n + -0.5030335784*VDS_n + -0.0052853036*VBS_n) / sqrt(1 + pow(0.5495961905 + -0.0016704479*VGS_n + -0.5030335784*VDS_n + -0.0052853036*VBS_n, 2));
        h1_30 = (-0.7767549157 + 0.0637279302*VGS_n + 0.6800379753*VDS_n + 0.0078635719*VBS_n) / sqrt(1 + pow(-0.7767549157 + 0.0637279302*VGS_n + 0.6800379753*VDS_n + 0.0078635719*VBS_n, 2));
