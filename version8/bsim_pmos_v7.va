// ============================================================
// BSIM_PMOS v7 - PMOS Neural Network Compact Model
// Based on: Tung & Hu, IEEE TED 2023/2024
// Architecture: 3 inputs -> 32 ISRU -> 32 ISRU -> 32 ISRU -> 1
// ============================================================
// PMOS Specific: All voltages negative
// ============================================================

`include "disciplines.vams"
`include "constants.vams"

module bsim_pmos_v7(d, g, s, b);
    inout d, g, s, b;
    electrical d, g, s, b;

    parameter real L = 1e-6 from (0:inf);
    parameter real W  = 10e-6 from (0:inf);

    real VGS, VDS, VBS, VGS_n, VDS_n, VBS_n;
    real h1_0, h1_1, h1_2, h1_3, h1_4, h1_5, h1_6, h1_7, h1_8, h1_9, h1_10, h1_11, h1_12, h1_13, h1_14, h1_15, h1_16, h1_17, h1_18, h1_19, h1_20, h1_21, h1_22, h1_23, h1_24, h1_25, h1_26, h1_27, h1_28, h1_29, h1_30, h1_31;
    real h2_0, h2_1, h2_2, h2_3, h2_4, h2_5, h2_6, h2_7, h2_8, h2_9, h2_10, h2_11, h2_12, h2_13, h2_14, h2_15, h2_16, h2_17, h2_18, h2_19, h2_20, h2_21, h2_22, h2_23, h2_24, h2_25, h2_26, h2_27, h2_28, h2_29, h2_30, h2_31;
    real h3_0, h3_1, h3_2, h3_3, h3_4, h3_5, h3_6, h3_7, h3_8, h3_9, h3_10, h3_11, h3_12, h3_13, h3_14, h3_15, h3_16, h3_17, h3_18, h3_19, h3_20, h3_21, h3_22, h3_23, h3_24, h3_25, h3_26, h3_27, h3_28, h3_29, h3_30, h3_31;
    real log10_Id, Ids, vds_ratio;

    // ISRU: f(x) = x / sqrt(1 + x^2)

    real mean_vgs = -0.4612068966;
    real std_vgs  = 0.3736814936;
    real mean_vds = -0.4036206897;
    real std_vds  = 0.3668991111;
    real mean_vbs = 0.2500000000;
    real std_vbs  = 0.1767766953;

    analog begin
        VGS = V(g, s);
        VDS = V(d, s);
        VBS = V(b, s);

        // PMOS: voltage clamping for negative voltages
        VGS = -0.5 + 0.8 * tanh((VGS + 0.5) / 0.8);
        VDS = -0.6 + 0.7 * tanh((VDS + 0.6) / 0.7);
        VBS = 0.25 + 0.3 * tanh((VBS - 0.25) / 0.3);

        VGS_n = (VGS - mean_vgs) / std_vgs;
        VDS_n = (VDS - mean_vds) / std_vds;
        VBS_n = (VBS - mean_vbs) / std_vbs;

        // Hidden Layer 1: 3 -> 32 ISRU

        h1_0 = (-0.2014397979 + 0.3112457395*VGS_n + -0.0250366777*VDS_n + 0.0297243353*VBS_n) / sqrt(1 + pow(-0.2014397979 + 0.3112457395*VGS_n + -0.0250366777*VDS_n + 0.0297243353*VBS_n, 2));
        h1_1 = (-0.3587471843 + -0.4342826903*VGS_n + -0.2526637018*VDS_n + 0.0266971886*VBS_n) / sqrt(1 + pow(-0.3587471843 + -0.4342826903*VGS_n + -0.2526637018*VDS_n + 0.0266971886*VBS_n, 2));
        h1_2 = (-0.0512951612 + -0.3664872646*VGS_n + 0.0089237150*VDS_n + -0.0532290377*VBS_n) / sqrt(1 + pow(-0.0512951612 + -0.3664872646*VGS_n + 0.0089237150*VDS_n + -0.0532290377*VBS_n, 2));
        h1_3 = (-0.2811123729 + -0.5730974078*VGS_n + 0.8239497542*VDS_n + -0.0330692008*VBS_n) / sqrt(1 + pow(-0.2811123729 + -0.5730974078*VGS_n + 0.8239497542*VDS_n + -0.0330692008*VBS_n, 2));
        h1_4 = (-0.0990628153 + -0.0579162091*VGS_n + 0.1931923926*VDS_n + 0.0142703261*VBS_n) / sqrt(1 + pow(-0.0990628153 + -0.0579162091*VGS_n + 0.1931923926*VDS_n + 0.0142703261*VBS_n, 2));
        h1_5 = (-0.7920165658 + 0.0038927451*VGS_n + 1.2915662527*VDS_n + 0.0010041344*VBS_n) / sqrt(1 + pow(-0.7920165658 + 0.0038927451*VGS_n + 1.2915662527*VDS_n + 0.0010041344*VBS_n, 2));
        h1_6 = (-0.5736588836 + 0.0371070057*VGS_n + 0.5048757792*VDS_n + 0.0029839701*VBS_n) / sqrt(1 + pow(-0.5736588836 + 0.0371070057*VGS_n + 0.5048757792*VDS_n + 0.0029839701*VBS_n, 2));
        h1_7 = (-0.5175983310 + 0.0318375640*VGS_n + 0.4619866014*VDS_n + -0.0030354466*VBS_n) / sqrt(1 + pow(-0.5175983310 + 0.0318375640*VGS_n + 0.4619866014*VDS_n + -0.0030354466*VBS_n, 2));
        h1_8 = (0.6571843624 + -0.0232051834*VGS_n + -0.5907521844*VDS_n + 0.0012541866*VBS_n) / sqrt(1 + pow(0.6571843624 + -0.0232051834*VGS_n + -0.5907521844*VDS_n + 0.0012541866*VBS_n, 2));
        h1_9 = (0.2760977745 + -0.0917043164*VGS_n + -0.0005915788*VDS_n + -0.0156805515*VBS_n) / sqrt(1 + pow(0.2760977745 + -0.0917043164*VGS_n + -0.0005915788*VDS_n + -0.0156805515*VBS_n, 2));
        h1_10 = (0.1091248989 + -0.3519286215*VGS_n + 0.0793521404*VDS_n + -0.0368027277*VBS_n) / sqrt(1 + pow(0.1091248989 + -0.3519286215*VGS_n + 0.0793521404*VDS_n + -0.0368027277*VBS_n, 2));
        h1_11 = (-0.3855031133 + -1.3862997293*VGS_n + -0.5434061289*VDS_n + -0.1067888886*VBS_n) / sqrt(1 + pow(-0.3855031133 + -1.3862997293*VGS_n + -0.5434061289*VDS_n + -0.1067888886*VBS_n, 2));
        h1_12 = (0.0291281752 + 0.4416674376*VGS_n + 0.0537819192*VDS_n + 0.0391674452*VBS_n) / sqrt(1 + pow(0.0291281752 + 0.4416674376*VGS_n + 0.0537819192*VDS_n + 0.0391674452*VBS_n, 2));
        h1_13 = (0.2591897249 + 0.0874392316*VGS_n + 0.0951219648*VDS_n + 0.0305970013*VBS_n) / sqrt(1 + pow(0.2591897249 + 0.0874392316*VGS_n + 0.0951219648*VDS_n + 0.0305970013*VBS_n, 2));
        h1_14 = (-0.1225913316 + -0.2665715814*VGS_n + -0.0139435623*VDS_n + -0.0946484655*VBS_n) / sqrt(1 + pow(-0.1225913316 + -0.2665715814*VGS_n + -0.0139435623*VDS_n + -0.0946484655*VBS_n, 2));
        h1_15 = (0.4677946270 + -0.0159321651*VGS_n + -0.4176151156*VDS_n + -0.0041183732*VBS_n) / sqrt(1 + pow(0.4677946270 + -0.0159321651*VGS_n + -0.4176151156*VDS_n + -0.0041183732*VBS_n, 2));
        h1_16 = (-0.2692342997 + -0.1132013649*VGS_n + 0.3214407265*VDS_n + -0.0012940094*VBS_n) / sqrt(1 + pow(-0.2692342997 + -0.1132013649*VGS_n + 0.3214407265*VDS_n + -0.0012940094*VBS_n, 2));
        h1_17 = (0.2057926208 + 0.1143557578*VGS_n + 0.0027159220*VDS_n + -0.1844965816*VBS_n) / sqrt(1 + pow(0.2057926208 + 0.1143557578*VGS_n + 0.0027159220*VDS_n + -0.1844965816*VBS_n, 2));
        h1_18 = (-0.0502535477 + 0.0555192865*VGS_n + -0.0053346008*VDS_n + 0.0015344872*VBS_n) / sqrt(1 + pow(-0.0502535477 + 0.0555192865*VGS_n + -0.0053346008*VDS_n + 0.0015344872*VBS_n, 2));
        h1_19 = (0.3248743713 + 0.0329384841*VGS_n + -0.3163277507*VDS_n + -0.0039062311*VBS_n) / sqrt(1 + pow(0.3248743713 + 0.0329384841*VGS_n + -0.3163277507*VDS_n + -0.0039062311*VBS_n, 2));
