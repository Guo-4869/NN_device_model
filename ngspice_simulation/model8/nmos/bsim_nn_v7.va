        h1_21 = (-0.2126314491 + 0.0047465693*VGS_n + 0.0283116549*VDS_n + -0.0107454667*VBS_n) / sqrt(1 + pow(-0.2126314491 + 0.0047465693*VGS_n + 0.0283116549*VDS_n + -0.0107454667*VBS_n, 2));
        h1_22 = (-0.0850291476 + 0.7401853800*VGS_n + 0.0429931097*VDS_n + 0.0253818445*VBS_n) / sqrt(1 + pow(-0.0850291476 + 0.7401853800*VGS_n + 0.0429931097*VDS_n + 0.0253818445*VBS_n, 2));
        h1_23 = (0.2662702501 + -0.0790299550*VGS_n + 0.0963845626*VDS_n + 0.1981101185*VBS_n) / sqrt(1 + pow(0.2662702501 + -0.0790299550*VGS_n + 0.0963845626*VDS_n + 0.1981101185*VBS_n, 2));
        h1_24 = (0.2126139849 + 0.1057967320*VGS_n + 0.0527842231*VDS_n + 0.0188796371*VBS_n) / sqrt(1 + pow(0.2126139849 + 0.1057967320*VGS_n + 0.0527842231*VDS_n + 0.0188796371*VBS_n, 2));
        h1_25 = (0.4474797547 + -0.1184564009*VGS_n + 0.5160073638*VDS_n + -0.0048405319*VBS_n) / sqrt(1 + pow(0.4474797547 + -0.1184564009*VGS_n + 0.5160073638*VDS_n + -0.0048405319*VBS_n, 2));
        h1_26 = (-0.3687607348 + -0.0418975279*VGS_n + -0.2406431735*VDS_n + 0.0060931309*VBS_n) / sqrt(1 + pow(-0.3687607348 + -0.0418975279*VGS_n + -0.2406431735*VDS_n + 0.0060931309*VBS_n, 2));
        h1_27 = (-0.2520678937 + -0.1502958089*VGS_n + 0.1369732320*VDS_n + -0.0009092315*VBS_n) / sqrt(1 + pow(-0.2520678937 + -0.1502958089*VGS_n + 0.1369732320*VDS_n + -0.0009092315*VBS_n, 2));
        h1_28 = (-0.2615657449 + 0.0446782149*VGS_n + -0.2630150318*VDS_n + -0.0006106129*VBS_n) / sqrt(1 + pow(-0.2615657449 + 0.0446782149*VGS_n + -0.2630150318*VDS_n + -0.0006106129*VBS_n, 2));
        h1_29 = (-0.7567860484 + 0.0063060527*VGS_n + -0.6893059015*VDS_n + -0.0060635949*VBS_n) / sqrt(1 + pow(-0.7567860484 + 0.0063060527*VGS_n + -0.6893059015*VDS_n + -0.0060635949*VBS_n, 2));
        h1_30 = (0.2670581639 + -0.0854771882*VGS_n + 0.3510657251*VDS_n + -0.0088692345*VBS_n) / sqrt(1 + pow(0.2670581639 + -0.0854771882*VGS_n + 0.3510657251*VDS_n + -0.0088692345*VBS_n, 2));
