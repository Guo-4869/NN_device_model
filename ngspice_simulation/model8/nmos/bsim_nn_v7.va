// ============================================================
// BSIM_NN v7 - Neural Network Compact MOSFET Model
// Based on: Tung & Hu, IEEE TED 2023/2024
// Architecture: 3 inputs -> 32 ISRU -> 32 ISRU -> 32 ISRU -> 1
// ============================================================
// SPICE Convergence Features:
//   - ISRU activation: no exp(), smooth C^inf nonlinearity
//   - Smooth tanh-based input range clamping
//   - Minimum std = 0.05 to prevent division by zero
//   - Weight-regularized: |W| < 5.0 to avoid activation saturation
//   - Smooth VDS->0 transition via rational function
// ============================================================

`include "disciplines.vams"
`include "constants.vams"

module bsim_nn_v7(d, g, s, b);
    inout d, g, s, b;
    electrical d, g, s, b;

    parameter real L = 1e-6 from (0:inf);
    parameter real W  = 10e-6 from (0:inf);

    real VGS, VDS, VBS, VGS_n, VDS_n, VBS_n;
    real h1_0, h1_1, h1_2, h1_3, h1_4, h1_5, h1_6, h1_7, h1_8, h1_9, h1_10, h1_11, h1_12, h1_13, h1_14, h1_15, h1_16, h1_17, h1_18, h1_19, h1_20, h1_21, h1_22, h1_23, h1_24, h1_25, h1_26, h1_27, h1_28, h1_29, h1_30, h1_31;
    real h2_0, h2_1, h2_2, h2_3, h2_4, h2_5, h2_6, h2_7, h2_8, h2_9, h2_10, h2_11, h2_12, h2_13, h2_14, h2_15, h2_16, h2_17, h2_18, h2_19, h2_20, h2_21, h2_22, h2_23, h2_24, h2_25, h2_26, h2_27, h2_28, h2_29, h2_30, h2_31;
    real h3_0, h3_1, h3_2, h3_3, h3_4, h3_5, h3_6, h3_7, h3_8, h3_9, h3_10, h3_11, h3_12, h3_13, h3_14, h3_15, h3_16, h3_17, h3_18, h3_19, h3_20, h3_21, h3_22, h3_23, h3_24, h3_25, h3_26, h3_27, h3_28, h3_29, h3_30, h3_31;
    real log10_Id, Ids, vds_ratio;

    // ISRU: f(x) = x / sqrt(1 + x^2)
    // Bounded (-1, 1), smooth, no exp(), Verilog-A friendly

    real mean_vgs = 0.4612068966;
    real std_vgs  = 0.3736814936;
    real mean_vds = 0.4036206897;
    real std_vds  = 0.3668991111;
    real mean_vbs = -0.2500000000;
    real std_vbs  = 0.1767766953;

    analog begin
        VGS = V(g, s);
        VDS = V(d, s);
        VBS = V(b, s);

        // Smooth tanh-based input clamping
        VGS = 0.5 + 0.8 * tanh((VGS - 0.5) / 0.8);
        VDS = 0.6 + 0.7 * tanh((VDS - 0.6) / 0.7);
        VBS = -0.25 + 0.3 * tanh((VBS + 0.25) / 0.3);

        VGS_n = (VGS - mean_vgs) / std_vgs;
        VDS_n = (VDS - mean_vds) / std_vds;
        VBS_n = (VBS - mean_vbs) / std_vbs;

        // Hidden Layer 1: 3 -> 32 ISRU

        h1_0 = (-0.7151181102 + 0.0379425846*VGS_n + -0.6919497848*VDS_n + -0.0030990245*VBS_n) / sqrt(1 + pow(-0.7151181102 + 0.0379425846*VGS_n + -0.6919497848*VDS_n + -0.0030990245*VBS_n, 2));
        h1_1 = (0.0175793283 + -0.5941464305*VGS_n + -0.0847255141*VDS_n + -0.0353618190*VBS_n) / sqrt(1 + pow(0.0175793283 + -0.5941464305*VGS_n + -0.0847255141*VDS_n + -0.0353618190*VBS_n, 2));
        h1_2 = (0.0769711211 + -0.4548766315*VGS_n + -0.1398880631*VDS_n + -0.0298671741*VBS_n) / sqrt(1 + pow(0.0769711211 + -0.4548766315*VGS_n + -0.1398880631*VDS_n + -0.0298671741*VBS_n, 2));
        h1_3 = (0.0101124719 + -0.6344576478*VGS_n + 0.0309316497*VDS_n + -0.0550001487*VBS_n) / sqrt(1 + pow(0.0101124719 + -0.6344576478*VGS_n + 0.0309316497*VDS_n + -0.0550001487*VBS_n, 2));
        h1_4 = (-0.0191175602 + -0.6569867730*VGS_n + 0.2076922655*VDS_n + -0.0435115844*VBS_n) / sqrt(1 + pow(-0.0191175602 + -0.6569867730*VGS_n + 0.2076922655*VDS_n + -0.0435115844*VBS_n, 2));
        h1_5 = (0.6112781167 + 0.0353080370*VGS_n + 0.5309495926*VDS_n + -5.6660734117e-05*VBS_n) / sqrt(1 + pow(0.6112781167 + 0.0353080370*VGS_n + 0.5309495926*VDS_n + -5.6660734117e-05*VBS_n, 2));
        h1_6 = (-0.5793870091 + -0.0302186999*VGS_n + -1.1430873871*VDS_n + -0.0088303760*VBS_n) / sqrt(1 + pow(-0.5793870091 + -0.0302186999*VGS_n + -1.1430873871*VDS_n + -0.0088303760*VBS_n, 2));
        h1_7 = (-0.3331785798 + -0.0265787188*VGS_n + -0.1155414209*VDS_n + 0.0050735641*VBS_n) / sqrt(1 + pow(-0.3331785798 + -0.0265787188*VGS_n + -0.1155414209*VDS_n + 0.0050735641*VBS_n, 2));
        h1_8 = (0.0771622136 + -0.2291213721*VGS_n + -0.0381519645*VDS_n + -0.1040363833*VBS_n) / sqrt(1 + pow(0.0771622136 + -0.2291213721*VGS_n + -0.0381519645*VDS_n + -0.1040363833*VBS_n, 2));
        h1_9 = (0.1725972593 + -0.0139167896*VGS_n + -0.0009451922*VDS_n + -0.0383831710*VBS_n) / sqrt(1 + pow(0.1725972593 + -0.0139167896*VGS_n + -0.0009451922*VDS_n + -0.0383831710*VBS_n, 2));
        h1_10 = (-0.4046212733 + 0.0282616690*VGS_n + -0.3739931583*VDS_n + 0.0003772806*VBS_n) / sqrt(1 + pow(-0.4046212733 + 0.0282616690*VGS_n + -0.3739931583*VDS_n + 0.0003772806*VBS_n, 2));
        h1_11 = (0.1665048152 + -0.3667104840*VGS_n + -0.2021843493*VDS_n + -0.0808083713*VBS_n) / sqrt(1 + pow(0.1665048152 + -0.3667104840*VGS_n + -0.2021843493*VDS_n + -0.0808083713*VBS_n, 2));
        h1_12 = (0.5801590085 + 0.0686051324*VGS_n + 0.4488415420*VDS_n + 0.0116122942*VBS_n) / sqrt(1 + pow(0.5801590085 + 0.0686051324*VGS_n + 0.4488415420*VDS_n + 0.0116122942*VBS_n, 2));
        h1_13 = (-0.3370967507 + -0.0244673453*VGS_n + -0.1207456887*VDS_n + -0.0148101132*VBS_n) / sqrt(1 + pow(-0.3370967507 + -0.0244673453*VGS_n + -0.1207456887*VDS_n + -0.0148101132*VBS_n, 2));
        h1_14 = (-0.0566714332 + -0.8016045690*VGS_n + -0.3824392259*VDS_n + -0.0803729892*VBS_n) / sqrt(1 + pow(-0.0566714332 + -0.8016045690*VGS_n + -0.3824392259*VDS_n + -0.0803729892*VBS_n, 2));
        h1_15 = (-0.7018198371 + -0.0239697173*VGS_n + -0.6632022858*VDS_n + -0.0009303506*VBS_n) / sqrt(1 + pow(-0.7018198371 + -0.0239697173*VGS_n + -0.6632022858*VDS_n + -0.0009303506*VBS_n, 2));
        h1_16 = (0.1886882186 + -0.0568496175*VGS_n + 0.2524833381*VDS_n + -0.0358765572*VBS_n) / sqrt(1 + pow(0.1886882186 + -0.0568496175*VGS_n + 0.2524833381*VDS_n + -0.0358765572*VBS_n, 2));
        h1_17 = (-0.6326409578 + 0.0110722743*VGS_n + -0.5733373165*VDS_n + 0.0101721305*VBS_n) / sqrt(1 + pow(-0.6326409578 + 0.0110722743*VGS_n + -0.5733373165*VDS_n + 0.0101721305*VBS_n, 2));
        h1_18 = (-0.5087573528 + -0.0437433310*VGS_n + -0.3874987066*VDS_n + -0.0054767518*VBS_n) / sqrt(1 + pow(-0.5087573528 + -0.0437433310*VGS_n + -0.3874987066*VDS_n + -0.0054767518*VBS_n, 2));
        h1_19 = (0.3575133383 + -0.0101368614*VGS_n + 0.3279509246*VDS_n + -0.0162917413*VBS_n) / sqrt(1 + pow(0.3575133383 + -0.0101368614*VGS_n + 0.3279509246*VDS_n + -0.0162917413*VBS_n, 2));
